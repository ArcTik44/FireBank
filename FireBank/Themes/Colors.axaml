<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

   
    <Color x:Key="SurfaceBase">#0E0F12</Color>
    <Color x:Key="Surface1">#15171C</Color>
    <Color x:Key="Surface2">#1C1F26</Color>
    <Color x:Key="Surface3">#242830</Color>
    <Color x:Key="SurfaceLine">#2C313A</Color>
    <Color x:Key="SurfaceMuted">#1A1D23</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#ECECEE</Color>
    <Color x:Key="TextSecondary">#A8ADB6</Color>
    <Color x:Key="TextMuted">#6E7480</Color>
    <Color x:Key="TextOnAccent">#15110D</Color>

   
    <Color x:Key="AccentCopper">#D08948</Color>
    <Color x:Key="AccentCopperHover">#E29A57</Color>
    <Color x:Key="AccentCopperPressed">#B47236</Color>
    <Color x:Key="AccentEmber">#FF7A2E</Color>
    <Color x:Key="AccentDeep">#8C3F19</Color>
    <Color x:Key="AccentGlow">#33FF7A2E</Color>

    <Color x:Key="Success">#3FB27F</Color>
    <Color x:Key="Warning">#E0A53A</Color>
    <Color x:Key="Danger">#E25A4A</Color>
    <Color x:Key="DangerSoft">#3A1E1B</Color>

    <SolidColorBrush x:Key="SurfaceBaseBrush" Color="{StaticResource SurfaceBase}"/>
    <SolidColorBrush x:Key="Surface1Brush" Color="{StaticResource Surface1}"/>
    <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2}"/>
    <SolidColorBrush x:Key="Surface3Brush" Color="{StaticResource Surface3}"/>
    <SolidColorBrush x:Key="SurfaceLineBrush" Color="{StaticResource SurfaceLine}"/>
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource SurfaceMuted}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccent}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentCopper}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentCopperHover}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentCopperPressed}"/>
    <SolidColorBrush x:Key="AccentEmberBrush" Color="{StaticResource AccentEmber}"/>
    <SolidColorBrush x:Key="AccentDeepBrush" Color="{StaticResource AccentDeep}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="DangerSoftBrush" Color="{StaticResource DangerSoft}"/>

    <LinearGradientBrush x:Key="EmberGradientBrush" StartPoint="0%,0%" EndPoint="100%,0%">
        <GradientStop Color="#1A1D23" Offset="0.0"/>
        <GradientStop Color="#2A1F18" Offset="0.6"/>
        <GradientStop Color="#3A2415" Offset="1.0"/>
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="WindowBackgroundBrush"
                         Center="80%,15%" GradientOrigin="80%,15%"
                         RadiusX="0.9" RadiusY="0.9">
        <GradientStop Color="#1B130E" Offset="0.0"/>
        <GradientStop Color="#121317" Offset="0.45"/>
        <GradientStop Color="#0E0F12" Offset="1.0"/>
    </RadialGradientBrush>

    <CornerRadius x:Key="RadiusSm">6</CornerRadius>
    <CornerRadius x:Key="RadiusMd">10</CornerRadius>
    <CornerRadius x:Key="RadiusLg">14</CornerRadius>
    <Thickness x:Key="PaddingControl">12,8</Thickness>
    <Thickness x:Key="PaddingCard">20</Thickness>

    <x:Double x:Key="FontSizeXs">11</x:Double>
    <x:Double x:Key="FontSizeSm">12</x:Double>
    <x:Double x:Key="FontSizeBase">13</x:Double>
    <x:Double x:Key="FontSizeMd">14</x:Double>
    <x:Double x:Key="FontSizeLg">18</x:Double>
    <x:Double x:Key="FontSizeXl">22</x:Double>
    <x:Double x:Key="FontSizeXxl">28</x:Double>

    <SolidColorBrush x:Key="PrimaryBackground" Color="{StaticResource AccentCopper}"/>

</ResourceDictionary>
