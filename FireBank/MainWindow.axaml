<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FireBank.MainWindow"
        Title="FireBank"
        Width="400" Height="300">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
        <TextBlock Text="Vítejte ve FireBank!" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        <Button Content="Přihlásit se" Width="150" HorizontalContentAlignment="Center" Click="GoToLogin_Click"/>
        <Button Content="Registrovat se" Width="150" HorizontalContentAlignment="Center" Click="GoToRegister_Click"/>
    </StackPanel>
</Window>
