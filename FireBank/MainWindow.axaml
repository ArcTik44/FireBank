<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FireBank.MainWindow"
        Title="FireBank"
        Width="800" Height="600"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Border Classes="card"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="380" Padding="32">
            <StackPanel Spacing="14" HorizontalAlignment="Stretch">
                <TextBlock Text="FireBank" Classes="brand" HorizontalAlignment="Center"/>
                <Border Classes="accent-line" Margin="0,0,0,12"/>

                <Button Content="Přihlásit se"
                        Classes="accent"
                        HorizontalAlignment="Stretch"
                        Click="GoToLogin_Click"/>
                <Button Content="Registrovat se"
                        HorizontalAlignment="Stretch"
                        Click="GoToRegister_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
