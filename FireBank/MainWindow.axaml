<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:FireBank.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="FireBank.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="FireBank">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
		<TextBlock Text="Welcome to FireBank!" FontSize="24" HorizontalAlignment="Center" Margin="0,20"/>
        <Button HorizontalContentAlignment="Center" Content="Login" Width="100" HorizontalAlignment="Center" Command="{Binding GoToLoginCommand}" Margin="0,10"/>
        <Button HorizontalContentAlignment="Center" Content="Register" Width="100" HorizontalAlignment="Center" Command="{Binding GoToRegisterCommand}" Margin="0,10"/>
    </StackPanel>
</Window>
