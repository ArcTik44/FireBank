<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FireBank.ViewModels"
        x:Class="FireBank.NewTransaction"
        x:DataType="vm:NewTransactionViewModel"
        Title="Nová transakce"
        Width="600" Height="420"
        CanResize="False">

    <StackPanel Margin="24" Spacing="12">

        <TextBlock Text="Nová transakce" FontSize="18" FontWeight="Bold"
                   Margin="0,0,0,8"/>

        <TextBlock Text="Z účtu:"/>
        <ComboBox ItemsSource="{Binding UserAccounts}"
                  SelectedItem="{Binding SelectedFromAccount}"
                  HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Text="{Binding AvailableBalance}" Foreground="Gray" FontSize="12"/>

        <TextBlock Text="Na účet (číslo účtu):"/>
        <TextBox Text="{Binding ToAccountNumber}"
                 PlaceholderText="např. 1234567890/0100"
                 HorizontalAlignment="Stretch"/>

        <TextBlock Text="Částka:"/>
        <NumericUpDown Value="{Binding Amount}"
                       Minimum="0"
                       FormatString="N2"
                       HorizontalAlignment="Stretch"/>

        <TextBlock Text="Poznámka:"/>
        <TextBox Text="{Binding Note}"
                 PlaceholderText="Volitelná poznámka"
                 HorizontalAlignment="Stretch"/>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        <StackPanel Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Zrušit" Command="{Binding CancelCommand}" Width="100"/>
            <Button Content="Odeslat" Command="{Binding SendCommand}"
                    Width="100" Classes="accent"/>
        </StackPanel>

    </StackPanel>
</Window>