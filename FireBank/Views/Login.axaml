<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="using:FireBank.ViewModels"
        x:Class="FireBank.Views.Login"
        x:DataType="viewmodels:LoginViewModel"
        Title="Přihlášení"
        Width="800" Height="600"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Border Classes="card"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="380" Padding="32">
            <StackPanel Spacing="6">
                <TextBlock Text="FireBank" Classes="brand" HorizontalAlignment="Center"/>
                <TextBlock Text="Přihlášení do účtu"
                           Classes="subtle" HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <Border Classes="accent-line" Margin="0,0,0,12"/>

                <TextBlock Text="Email" Classes="label"/>
                <TextBox Text="{Binding Email}" PlaceholderText="user@firebank.com"/>

                <TextBlock Text="Heslo" Classes="label"/>
                <TextBox Name="PasswordTextBox" PasswordChar="•"
                         Text="{Binding Password}" PlaceholderText="••••••••"/>

                <TextBlock Text="{Binding ErrorMessage}" Classes="error"
                           Margin="0,8,0,0"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <Button Content="Přihlásit se" Classes="accent"
                        HorizontalAlignment="Stretch" Margin="0,16,0,0"
                        Command="{Binding LoginCommand}"/>
                <Button Content="Nemám účet – Registrovat se" Classes="ghost"
                        HorizontalAlignment="Stretch"
                        Command="{Binding GoToRegisterCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
