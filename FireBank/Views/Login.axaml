<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="using:FireBank.ViewModels"
        x:Class="FireBank.Views.Login"
        x:DataType="viewmodels:LoginViewModel"
        Title="FireBank"
        Width="900" Height="600"
        Background="#0F1117">

  <Grid ColumnDefinitions="1.1*,0.9*">

    <!-- Levý panel – branding -->
    <Border Grid.Column="0" Background="#0A0E1A">
      <Grid RowDefinitions="*,Auto,*">
        <StackPanel Grid.Row="1" Margin="56,0">

          <!-- Logo -->
          <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,48">
            <Border Background="#4B9EFF" CornerRadius="12" Width="44" Height="44"
                    VerticalAlignment="Center">
              <TextBlock Text="F" FontSize="22" FontWeight="Bold"
                         Foreground="White"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="FireBank" FontSize="24" FontWeight="Bold"
                       Foreground="White" VerticalAlignment="Center"/>
          </StackPanel>

          <TextBlock Text="Spravujte své finance" Classes="title"
                     FontSize="32" TextWrapping="Wrap"
                     Margin="0,0,0,16"/>
          <TextBlock Classes="subtitle"
                     Text="Bezpečný přístup k vašim účtům a transakcím kdekoliv a kdykoliv."
                     TextWrapping="Wrap" FontSize="15" LineHeight="22"/>

          <!-- Dekorativní boxy -->
          <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,48,0,0">
            <Border Background="#161B27" CornerRadius="12" Padding="16,12"
                    BorderBrush="#1E2840" BorderThickness="1">
              <StackPanel>
                <TextBlock Text="Šifrování" Classes="subtitle" FontSize="11"/>
                <TextBlock Text="AES-256" FontWeight="SemiBold" Foreground="#34D399" FontSize="14"/>
              </StackPanel>
            </Border>
            <Border Background="#161B27" CornerRadius="12" Padding="16,12"
                    BorderBrush="#1E2840" BorderThickness="1">
              <StackPanel>
                <TextBlock Text="Dostupnost" Classes="subtitle" FontSize="11"/>
                <TextBlock Text="24 / 7" FontWeight="SemiBold" Foreground="#4B9EFF" FontSize="14"/>
              </StackPanel>
            </Border>
          </StackPanel>

        </StackPanel>
      </Grid>
    </Border>

    <!-- Pravý panel – formulář -->
    <Grid Grid.Column="1" Background="#0F1117">
      <Border VerticalAlignment="Center" HorizontalAlignment="Center" Width="340">
        <StackPanel Spacing="0">

          <TextBlock Text="Přihlásit se" Classes="title" FontSize="26"
                     Margin="0,0,0,6"/>
          <TextBlock Text="Zadejte své přihlašovací údaje" Classes="subtitle"
                     Margin="0,0,0,32"/>

          <!-- Email -->
          <TextBlock Text="EMAIL" Classes="label" FontSize="11"
                     Margin="0,0,0,6"/>
          <TextBox Text="{Binding Email}" PlaceholderText="vas@email.cz"
                   Margin="0,0,0,16"/>

          <!-- Heslo -->
          <TextBlock Text="HESLO" Classes="label" FontSize="11"
                     Margin="0,0,0,6"/>
          <TextBox Name="PasswordTextBox" PasswordChar="*"
                   Text="{Binding Password}" PlaceholderText="••••••••"
                   Margin="0,0,0,8"/>

          <!-- Chybová zpráva -->
          <Border Background="#2D1B1B" CornerRadius="8" Padding="12,10"
                  Margin="0,4,0,16"
                  IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}" Classes="error"
                       TextWrapping="Wrap" Margin="0"/>
          </Border>

          <!-- Přihlásit -->
          <Button Content="Přihlásit se" Classes="accent"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Height="44" FontSize="15"
                  Margin="0,0,0,12"
                  Command="{Binding LoginCommand}"/>

          <!-- Registrace -->
          <Button Content="Nemám účet – Registrovat se"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Height="42"
                  Command="{Binding GoToRegisterCommand}"/>

        </StackPanel>
      </Border>
    </Grid>

  </Grid>
</Window>
