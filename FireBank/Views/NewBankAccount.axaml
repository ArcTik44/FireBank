<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FireBank.ViewModels"
        x:Class="FireBank.NewBankAccount"
        x:DataType="vm:NewBankAccountViewModel"
        Title="Nový bankovní účet"
        Width="520" Height="460"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="24">
        <Border Classes="card" Padding="28">
            <StackPanel Spacing="6">
                <TextBlock Text="Nový bankovní účet" Classes="h3"/>
                <TextBlock Text="Vyberte typ a měnu nového účtu"
                           Classes="subtle" Margin="0,0,0,8"/>
                <Border Classes="accent-line" Margin="0,0,0,12"/>

                <TextBlock Text="Typ účtu" Classes="label"/>
                <ComboBox ItemsSource="{Binding AccountTypes}"
                          SelectedItem="{Binding SelectedAccountType}"
                          HorizontalAlignment="Stretch"/>

                <TextBlock Text="Měna" Classes="label"/>
                <ComboBox ItemsSource="{Binding Currencies}"
                          SelectedItem="{Binding SelectedCurrency}"
                          HorizontalAlignment="Stretch"/>

                <TextBlock Text="Počáteční zůstatek" Classes="label"/>
                <NumericUpDown Value="{Binding InitialBalance}"
                               Minimum="0"
                               FormatString="N2"
                               HorizontalAlignment="Stretch"/>

                <TextBlock Text="{Binding ErrorMessage}" Classes="error"
                           Margin="0,8,0,0"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,20,0,0">
                    <Button Grid.Column="0" Content="Zrušit" Classes="ghost"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CancelCommand}"/>
                    <Button Grid.Column="1" Content="Vytvořit účet" Classes="accent"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CreateAccountCommand}"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
