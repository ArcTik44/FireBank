<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FireBank.ViewModels"
        x:Class="FireBank.NewBankAccount"
        x:DataType="vm:NewBankAccountViewModel"
        Title="Nový bankovní účet"
        Width="600" Height="420"
        CanResize="False">

    <StackPanel Margin="24" Spacing="12">

        <TextBlock Text="Nový bankovní účet" FontSize="18" FontWeight="Bold"
                   Margin="0,0,0,8"/>

        <TextBlock Text="Typ účtu:"/>
        <ComboBox ItemsSource="{Binding AccountTypes}"
                  SelectedItem="{Binding SelectedAccountType}"
                  HorizontalAlignment="Stretch"/>

        <TextBlock Text="Měna:"/>
        <ComboBox ItemsSource="{Binding Currencies}"
                  SelectedItem="{Binding SelectedCurrency}"
                  HorizontalAlignment="Stretch"/>

        <TextBlock Text="Počáteční zůstatek:"/>
        <NumericUpDown Value="{Binding InitialBalance}"
                       Minimum="0"
                       FormatString="N2"
                       HorizontalAlignment="Stretch"/>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Zrušit" Command="{Binding CancelCommand}" Width="100"/>
            <Button Content="Vytvořit" Command="{Binding CreateAccountCommand}"
                    Width="100" Classes="accent"/>
        </StackPanel>

    </StackPanel>
</Window>