<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FireBank.ViewModels"
        x:Class="FireBank.NewBankAccount"
        x:DataType="vm:NewBankAccountViewModel"
        Title="FireBank – Nový účet"
        Width="480" Height="420"
        CanResize="False"
        Background="#0F1117">

  <Border Margin="32" Background="#0F1117">
    <StackPanel Spacing="0">

      <!-- Záhlaví -->
      <StackPanel Margin="0,0,0,28">
        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,6">
          <Border Background="#1A2744" CornerRadius="10"
                  Width="36" Height="36">
            <TextBlock Text="🏦" FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="Nový bankovní účet" Classes="title" FontSize="20"
                     VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock Text="Vytvořte si nový účet" Classes="subtitle"
                   Margin="48,0,0,0"/>
      </StackPanel>

      <!-- Typ účtu -->
      <TextBlock Text="TYP ÚČTU" Classes="label" FontSize="11" Margin="0,0,0,6"/>
      <ComboBox ItemsSource="{Binding AccountTypes}"
                SelectedItem="{Binding SelectedAccountType}"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,16"/>

      <!-- Měna -->
      <TextBlock Text="MĚNA" Classes="label" FontSize="11" Margin="0,0,0,6"/>
      <ComboBox ItemsSource="{Binding Currencies}"
                SelectedItem="{Binding SelectedCurrency}"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,16"/>

      <!-- Počáteční zůstatek -->
      <TextBlock Text="POČÁTEČNÍ ZŮSTATEK" Classes="label" FontSize="11" Margin="0,0,0,6"/>
      <NumericUpDown Value="{Binding InitialBalance}"
                     Minimum="0"
                     FormatString="N2"
                     HorizontalAlignment="Stretch"
                     Margin="0,0,0,8"/>

      <!-- Chybová zpráva -->
      <Border Background="#2D1B1B" CornerRadius="8" Padding="12,10"
              Margin="0,4,0,20"
              IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <TextBlock Text="{Binding ErrorMessage}" Classes="error"
                   TextWrapping="Wrap" Margin="0"/>
      </Border>

      <!-- Tlačítka -->
      <Grid ColumnDefinitions="*,12,*">
        <Button Grid.Column="0" Content="Zrušit"
                Command="{Binding CancelCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Height="42"/>
        <Button Grid.Column="2" Content="Vytvořit účet"
                Classes="accent"
                Command="{Binding CreateAccountCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Height="42"/>
      </Grid>

    </StackPanel>
  </Border>
</Window>
