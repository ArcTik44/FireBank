<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="using:FireBank.ViewModels"
        x:Class="FireBank.Views.Register"
        Title="Registrace"
        Width="800" Height="600"
        x:DataType="viewmodels:RegisterViewModel"
        >

    <Grid ColumnDefinitions="200,200" HorizontalAlignment="Center" 
      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="15">

    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Registrace nového uživatele" />

    <TextBlock Grid.Row="1" Grid.Column="0" Text="Jméno:" />
    <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding FirstName}" Width="200" />

    <TextBlock Grid.Row="2" Grid.Column="0" Text="Přijmení:" />
    <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding LastName}" Width="200" />

    <TextBlock Grid.Row="3" Grid.Column="0" Text="Email:" />
    <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding Email}" Width="200" />

    <TextBlock Grid.Row="4" Grid.Column="0" Text="Heslo:" />
    <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding Password}" PasswordChar="*" Name="PasswordBox" Width="200" />

    <TextBlock Grid.Row="5" Grid.Column="0" Text="Potvrzení hesla:" />
    <TextBox   Grid.Row="5" Grid.Column="1" Text="{Binding ConfirmPassword}" PasswordChar="*" Name="ConfirmPasswordBox" Width="200" />

    <CheckBox  Grid.Row="6" Grid.ColumnSpan="2" x:Name="AcceptTermsCheckBox"
               Content="Přijímám podmínky užití aplikace FireBank a zpracování osobních údajů"/>
    <Button    Grid.Row="7" Grid.Column="0"
               IsEnabled="{Binding #AcceptTermsCheckBox.IsChecked}"
               Content="Registrovat se" HorizontalContentAlignment="Center" Command="{Binding RegisterCommand}"/>
    <Button Grid.Row="7" Grid.Column="1"
            Content="Mám účet - Přihlásit se" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Command="{Binding GoToLoginCommand}"/>

</Grid>
</Window>
