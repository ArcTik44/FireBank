<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="using:FireBank.ViewModels"
        x:Class="FireBank.Views.Register"
        x:DataType="viewmodels:RegisterViewModel"
        Title="FireBank – Registrace"
        Width="900" Height="660"
        Background="#0F1117">

  <Grid ColumnDefinitions="1.1*,0.9*">

    <!-- Levý panel – branding -->
    <Border Grid.Column="0" Background="#0A0E1A">
      <Grid RowDefinitions="*,Auto,*">
        <StackPanel Grid.Row="1" Margin="56,0">

          <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,48">
            <Border Background="#4B9EFF" CornerRadius="12" Width="44" Height="44"
                    VerticalAlignment="Center">
              <TextBlock Text="F" FontSize="22" FontWeight="Bold"
                         Foreground="White"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="FireBank" FontSize="24" FontWeight="Bold"
                       Foreground="White" VerticalAlignment="Center"/>
          </StackPanel>

          <TextBlock Text="Začněte ještě dnes" Classes="title"
                     FontSize="32" TextWrapping="Wrap"
                     Margin="0,0,0,16"/>
          <TextBlock Classes="subtitle"
                     Text="Vytvořte si účet zdarma a mějte přehled o svých financích."
                     TextWrapping="Wrap" FontSize="15" LineHeight="22"/>

        </StackPanel>
      </Grid>
    </Border>

    <!-- Pravý panel – formulář -->
    <Grid Grid.Column="1" Background="#0F1117">
      <Border VerticalAlignment="Center" HorizontalAlignment="Center" Width="340">
        <StackPanel Spacing="0">

          <TextBlock Text="Nový účet" Classes="title" FontSize="26"
                     Margin="0,0,0,6"/>
          <TextBlock Text="Vyplňte registrační formulář" Classes="subtitle"
                     Margin="0,0,0,28"/>

          <!-- Jméno -->
          <TextBlock Text="JMÉNO" Classes="label" FontSize="11" Margin="0,0,0,6"/>
          <TextBox Text="{Binding FirstName}" PlaceholderText="Jan"
                   Margin="0,0,0,14"/>

          <!-- Příjmení -->
          <TextBlock Text="PŘÍJMENÍ" Classes="label" FontSize="11" Margin="0,0,0,6"/>
          <TextBox Text="{Binding LastName}" PlaceholderText="Novák"
                   Margin="0,0,0,14"/>

          <!-- Email -->
          <TextBlock Text="EMAIL" Classes="label" FontSize="11" Margin="0,0,0,6"/>
          <TextBox Text="{Binding Email}" PlaceholderText="vas@email.cz"
                   Margin="0,0,0,14"/>

          <!-- Heslo -->
          <TextBlock Text="HESLO" Classes="label" FontSize="11" Margin="0,0,0,6"/>
          <TextBox Text="{Binding Password}" PasswordChar="*"
                   Name="PasswordBox" PlaceholderText="Min. 8 znaků"
                   Margin="0,0,0,14"/>

          <!-- Potvrzení hesla -->
          <TextBlock Text="POTVRZENÍ HESLA" Classes="label" FontSize="11" Margin="0,0,0,6"/>
          <TextBox Text="{Binding ConfirmPassword}" PasswordChar="*"
                   Name="ConfirmPasswordBox" PlaceholderText="Zopakujte heslo"
                   Margin="0,0,0,16"/>

          <!-- Souhlas -->
          <CheckBox x:Name="AcceptTermsCheckBox"
                    Content="Přijímám podmínky užití FireBank"
                    Margin="0,0,0,8"/>

          <!-- Chybová zpráva -->
          <Border Background="#2D1B1B" CornerRadius="8" Padding="12,10"
                  Margin="0,0,0,16"
                  IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}" Classes="error"
                       TextWrapping="Wrap" Margin="0"/>
          </Border>

          <!-- Tlačítka -->
          <Button Content="Registrovat se" Classes="accent"
                  IsEnabled="{Binding #AcceptTermsCheckBox.IsChecked}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Height="44" FontSize="15"
                  Margin="0,0,0,12"
                  Command="{Binding RegisterCommand}"/>

          <Button Content="Mám účet – Přihlásit se"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Height="42"
                  Command="{Binding GoToLoginCommand}"/>

        </StackPanel>
      </Border>
    </Grid>

  </Grid>
</Window>
