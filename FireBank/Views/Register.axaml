<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="using:FireBank.ViewModels"
        x:Class="FireBank.Views.Register"
        x:DataType="viewmodels:RegisterViewModel"
        Title="Registrace"
        Width="800" Height="640"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Border Classes="card"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="460" Padding="32">
            <StackPanel Spacing="4">
                <TextBlock Text="FireBank" Classes="brand" HorizontalAlignment="Center"/>
                <TextBlock Text="Registrace nového uživatele"
                           Classes="subtle" HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <Border Classes="accent-line" Margin="0,0,0,12"/>

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnSpacing="12" RowSpacing="2">
                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Jméno" Classes="label"/>
                        <TextBox Text="{Binding FirstName}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1">
                        <TextBlock Text="Příjmení" Classes="label"/>
                        <TextBox Text="{Binding LastName}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2">
                        <TextBlock Text="Email" Classes="label"/>
                        <TextBox Text="{Binding Email}" PlaceholderText="vas@email.cz"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="Heslo" Classes="label"/>
                        <TextBox Text="{Binding Password}" PasswordChar="•" Name="PasswordBox"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1">
                        <TextBlock Text="Potvrzení hesla" Classes="label"/>
                        <TextBox Text="{Binding ConfirmPassword}" PasswordChar="•" Name="ConfirmPasswordBox"/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="AcceptTermsCheckBox" Margin="0,12,0,0"
                          Content="Přijímám podmínky užití aplikace FireBank a zpracování osobních údajů"/>

                <TextBlock Text="{Binding ErrorMessage}" Classes="error"
                           Margin="0,8,0,0"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,16,0,0">
                    <Button Grid.Column="0"
                            Content="Mám účet – Přihlásit se" Classes="ghost"
                            HorizontalAlignment="Stretch"
                            Command="{Binding GoToLoginCommand}"/>
                    <Button Grid.Column="1"
                            Content="Registrovat se" Classes="accent"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding #AcceptTermsCheckBox.IsChecked}"
                            Command="{Binding RegisterCommand}"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
