<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FireBank.Views.Register"
        Title="Registrace"
        Width="800" Height="600">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" Width="260" Margin="0,12">
        <TextBlock Text="Registrace" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,12"/>

        <TextBlock Text="Jméno:"/>
        <TextBox Name="FirstNameTextBox"/>

        <TextBlock Text="Příjmení:"/>
        <TextBox Name="LastNameTextBox"/>

        <TextBlock Text="Email:"/>
        <TextBox Name="EmailTextBox"/>

        <TextBlock Text="Heslo:"/>
        <TextBox Name="PasswordBox" PasswordChar="*"/>

        <TextBlock Text="Potvrzení hesla:"/>
        <TextBox Name="ConfirmPasswordBox" PasswordChar="*"/>

        <CheckBox Name="AcceptTermsCheckBox" Content="Souhlasím s podmínkami služby" Margin="0,8,0,0"/>

        <Button Content="Registrovat se"
                HorizontalContentAlignment="Center"
                HorizontalAlignment="Stretch"
                IsEnabled="{Binding #AcceptTermsCheckBox.IsChecked}"
                Click="GoToLogin_Click"
                Margin="0,4,0,0"/>
    </StackPanel>
</Window>
