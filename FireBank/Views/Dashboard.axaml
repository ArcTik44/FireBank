<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FireBank.ViewModels"
        x:Class="FireBank.Dashboard"
        x:DataType="vm:DashboardViewModel"
        Title="Dashboard"
        Width="800" Height="600">

    <DockPanel>

        <!-- Hlavička -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                    Background="#1a73e8" Height="50" Spacing="12">
            <TextBlock Text="{Binding WelcomeMessage}"
                       Foreground="White" FontSize="16"
                       VerticalAlignment="Center" Margin="16,0,0,0"/>
            <Button Content="Odhlásit" Command="{Binding LogoutCommand}"
                    VerticalAlignment="Center"/>
        </StackPanel>

        <TabControl>

            <!-- Účty -->
            <TabItem Header="Účty">
                <DockPanel>
                    <Button DockPanel.Dock="Top" Content="+ Nový účet"
                            Command="{Binding NewAccountCommand}"
                            HorizontalAlignment="Left" Margin="8"/>
                    <ListBox ItemsSource="{Binding Accounts}"
                             SelectedItem="{Binding SelectedAccount}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <TextBlock Text="{Binding AccountNumber}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding AccountType}"/>
                                    <TextBlock Text="{Binding Balance, StringFormat='{}{0:N2}'}"/>
                                    <TextBlock Text="{Binding Currency}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>

            <!-- Transakce -->
            <TabItem Header="Transakce">
                <DockPanel>
                    <Button DockPanel.Dock="Top" Content="+ Nová transakce"
                            Command="{Binding NewTransactionCommand}"
                            HorizontalAlignment="Left" Margin="8"/>
                    <ListBox ItemsSource="{Binding Transactions}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <TextBlock Text="{Binding Date, StringFormat='{}{0:dd.MM.yyyy}'}"/>
                                    <TextBlock Text="{Binding FromAccountNumber}"/>
                                    <TextBlock Text="→"/>
                                    <TextBlock Text="{Binding ToAccountNumber}"/>
                                    <TextBlock Text="{Binding Amount, StringFormat='{}{0:N2}'}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Note}" Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>